{
    "version": 2,
    "framework": null,
    "buildCommand": "mkdir -p public",
    "outputDirectory": "./",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        {
            "src": "/_vercel/assets/(.*)",
            "dest": "public/$1"
        },
        {
            "src": "/(.*).(js|css|png|jpg|jpeg|gif|ico|svg|json|webp)",
            "dest": "public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}